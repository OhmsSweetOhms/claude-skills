{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["role", "results"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["ieee_searcher", "web_searcher", "code_searcher", "citation_tracer"]
    },
    "mode": {
      "type": "string",
      "description": "Operating mode (e.g. 'fallback' if MCP unavailable)"
    },
    "queries_executed": {
      "oneOf": [
        { "type": "integer", "description": "Simple count of queries run" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "query": { "type": "string" },
              "tool": { "type": "string" },
              "result_count": { "type": "integer" }
            }
          },
          "description": "Detailed audit trail of what was searched"
        }
      ]
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "relevance"],
        "properties": {
          "title": { "type": "string" },
          "authors": { "type": "array", "items": { "type": "string" } },
          "year": { "type": "integer" },
          "venue": { "type": "string", "description": "Conference, journal, or publisher name" },
          "source": { "type": "string", "description": "Website or platform name (e.g. 'gnss-sdr.org', 'GitHub')" },

          "url": { "type": "string", "description": "Direct URL to the resource" },
          "doi": { "type": "string", "description": "DOI identifier if available (e.g. '10.3390/s24051416')" },

          "summary": { "type": "string", "description": "2-3 sentence summary in own words" },
          "relevance": { "type": "string", "enum": ["high", "medium", "low"] },
          "rationale": { "type": "string", "description": "Why this relevance level was assigned" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },

          "tags": {
            "type": "array", "items": { "type": "string" },
            "description": "Domain/topic tags for classification (e.g. 'AD9361', 'Zynq', 'PCPS')"
          },
          "flags": {
            "type": "array",
            "items": { "type": "string", "enum": ["foundational", "novel_approach", "contradicts", "has_code", "platform_specific", "open_access"] },
            "description": "Special markers that modify priority within tier"
          },

          "type": {
            "type": "string",
            "enum": ["paper", "thesis", "repo", "blog_post", "app_note", "tutorial", "trade_article", "presentation", "webpage"],
            "description": "Content type — helps gen_manifest.py classify without guessing"
          },

          "license": { "type": "string", "description": "For repos: SPDX license ID (e.g. 'MIT', 'GPL-3.0')" },
          "language": { "type": "string", "description": "For repos: primary programming language" },
          "stars": { "type": "integer", "description": "For repos: GitHub star count" },

          "local_file": {
            "type": "string",
            "description": "Relative path to local copy within session dir (e.g. 'pdfs/foo.pdf', 'blogs/bar.md'). Set by Claude after calling fetch_and_save.py."
          },
          "clone_repo": {
            "type": "boolean",
            "description": "Whether this repo was cloned to repos/"
          },

          "recommended_action": {
            "type": "string",
            "enum": ["read_full_paper", "skim", "skip", "clone_repo", "trace_citations"],
            "description": "What the user should do with this result — used in report Stage 4"
          },

          "cross_references": {
            "type": "array", "items": { "type": "string" },
            "description": "Titles of related results or cited papers"
          }
        }
      }
    },
    "merged_results": {
      "type": "array",
      "description": "Results added from a merged older session. Same schema as results[].",
      "items": { "$ref": "#/properties/results/items" }
    },
    "handoff_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target_role": { "type": "string" },
          "item": { "type": "string" },
          "source": { "type": "string" }
        }
      },
      "description": "Items to pass to another role"
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What the search did NOT find that was expected"
    }
  }
}
