{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["role", "query_topic", "queries_executed", "results", "gaps_identified"],
  "properties": {
    "role": {
      "type": "string",
      "enum": ["ieee_searcher", "web_searcher", "code_searcher", "citation_tracer"]
    },
    "query_topic": {
      "type": "string",
      "description": "The sub-question or search focus this role was assigned"
    },
    "queries_executed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "query": { "type": "string" },
          "tool": { "type": "string" },
          "result_count": { "type": "integer" }
        }
      },
      "description": "Audit trail of what was searched"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "source", "relevance", "relevance_rationale", "recommended_action"],
        "properties": {
          "title": { "type": "string" },
          "authors": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "year": { "type": "integer" },
          "venue": { "type": "string" },
          "abstract_summary": { "type": "string", "description": "2-3 sentence summary in own words" },
          "relevance": { "type": "string", "enum": ["high", "medium", "low"] },
          "relevance_rationale": { "type": "string" },
          "key_contribution": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1, "description": "How confident in the relevance assessment" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "flags": {
            "type": "array",
            "items": { "type": "string", "enum": ["foundational", "novel_approach", "contradicts", "has_code", "platform_specific", "open_access"] }
          },
          "recommended_action": { "type": "string", "enum": ["read_full_paper", "skim", "skip", "clone_repo", "trace_citations", "contact_author"] },
          "url_or_doi": { "type": "string" },
          "license": { "type": "string", "description": "For code repos only" },
          "cross_references": { "type": "array", "items": { "type": "string" }, "description": "Titles of other results this relates to" }
        }
      }
    },
    "gaps_identified": {
      "type": "array",
      "items": { "type": "string" },
      "description": "What the search did NOT find that was expected"
    },
    "suggested_followup_queries": {
      "type": "array",
      "items": { "type": "string" }
    },
    "handoff_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "target_role": { "type": "string" },
          "item": { "type": "string" },
          "reason": { "type": "string" }
        }
      },
      "description": "Items to pass to another role (e.g., repo URL found in a paper -> code_searcher)"
    }
  }
}
