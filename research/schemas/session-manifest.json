{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["session_id", "title", "date", "query", "status", "content", "sources"],
  "properties": {
    "session_id": { "type": "string", "description": "Session directory name (session-YYYYMMDD-HHMMSS)" },
    "title": { "type": "string", "description": "Report title from frontmatter" },
    "date": { "type": "string", "format": "date" },
    "query": { "type": "string", "description": "Original user query verbatim" },
    "status": { "type": "string", "enum": ["complete", "partial"] },
    "sources": {
      "type": "object",
      "description": "Tracks ALL sources referenced in results — both saved and unsaved. Built by gen_manifest.py from results/*.json.",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title", "status"],
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string", "description": "Direct URL (preferred identifier for dedup)" },
              "doi": { "type": "string", "description": "DOI if available" },
              "type": { "type": "string", "enum": ["paper", "thesis", "repo", "blog_post", "app_note", "tutorial", "trade_article", "presentation", "webpage"] },
              "tier": { "type": ["integer", "null"], "description": "1, 2, or null if not ranked" },
              "status": { "type": "string", "enum": ["saved", "cloned", "paywall", "fetch_failed", "not_attempted", "manual_needed"] },
              "local_paths": { "type": "array", "items": { "type": "string" }, "description": "Relative paths within session dir" },
              "found_by": { "type": "array", "items": { "type": "string" }, "description": "Roles that found this source" },
              "reason": { "type": ["string", "null"], "description": "Why not saved, if status != saved/cloned" }
            }
          }
        },
        "summary": {
          "type": "object",
          "properties": {
            "total": { "type": "integer" },
            "saved": { "type": "integer" },
            "cloned": { "type": "integer" },
            "paywall": { "type": "integer" },
            "fetch_failed": { "type": "integer" },
            "not_attempted": { "type": "integer" },
            "manual_needed": { "type": "integer" }
          }
        }
      }
    },
    "content": {
      "type": "object",
      "description": "Inventory of files on disk. Built by gen_manifest.py scanning directories.",
      "properties": {
        "pdfs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file", "title"],
            "properties": {
              "name": { "type": "string" },
              "file": { "type": "string", "description": "Relative path to .md text extraction" },
              "pdf": { "type": "string", "description": "Relative path to .pdf file" },
              "title": { "type": "string" },
              "url": { "type": "string", "description": "Source URL from file header" }
            }
          }
        },
        "blogs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file", "title"],
            "properties": {
              "name": { "type": "string" },
              "file": { "type": "string" },
              "url": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "app-notes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file", "title"],
            "properties": {
              "name": { "type": "string" },
              "file": { "type": "string" },
              "url": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "html": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "file", "title"],
            "properties": {
              "name": { "type": "string" },
              "file": { "type": "string" },
              "url": { "type": "string" },
              "title": { "type": "string" }
            }
          }
        },
        "repos": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "description": "owner/repo or directory name" },
              "github_url": { "type": "string" },
              "description": { "type": "string" },
              "language": { "type": "string" },
              "stars": { "type": ["integer", "null"] },
              "license": { "type": ["string", "null"] },
              "cloned": { "type": "boolean" },
              "cloned_to": { "type": "string", "description": "Relative path to cloned repo dir" },
              "metadata_file": { "type": "string", "description": "Relative path to gh-*.json" }
            }
          }
        }
      }
    }
  }
}
